hostname ALS1
!
boot-start-marker
boot-end-marker
!
!
no aaa new-model
system mtu routing 1500
vtp mode transparent
ip routing
!
!
no ip domain-lookup
ip domain-name CCNP.NET
!
!
!
!
!
!
!
!
spanning-tree mode pvst
spanning-tree extend system-id
!
vlan internal allocation policy ascending
!
vlan 99
 name MGMT1
!
vlan 100
 name LOCAL
!
vlan 110
